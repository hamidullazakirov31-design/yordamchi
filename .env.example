# ===== Yordamchi — muhit o'zgaruvchilari namunasi =====
# Haqiqiy qiymatlarni .env.local ga yozing (u git'ga kirmaydi).
# Vercel'da esa Project Settings → Environment Variables bo'limiga qo'shing.

# Telegram bot tokeni (BotFather'dan)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Ilovaga kirishga ruxsat etilgan yagona Telegram foydalanuvchi ID'si
ALLOWED_TELEGRAM_ID=1271615246

# Bot username'i (deep-link uchun, @ belgisisiz) — public
NEXT_PUBLIC_BOT_USERNAME=zxi540bot

# Ilova bazaviy URL'i — public
NEXT_PUBLIC_APP_URL=https://yordamchi-dusky.vercel.app

# Sessiya va auth-token JWT'lari uchun maxfiy kalit (kamida 32 bayt)
# Yaratish: openssl rand -hex 32
AUTH_SECRET=change-me-openssl-rand-hex-32

# Telegram webhook'ni himoyalash uchun maxfiy token
# Yaratish: openssl rand -hex 16
TELEGRAM_WEBHOOK_SECRET=change-me-openssl-rand-hex-16

# PostgreSQL (Neon) ulanishi — ilova uchun pooled URL
DATABASE_URL=postgresql://user:password@host-pooler.neon.tech/db?sslmode=require
# Migratsiyalar uchun to'g'ridan-to'g'ri (pgbouncer'siz) URL
DATABASE_URL_UNPOOLED=postgresql://user:password@host.neon.tech/db?sslmode=require

# Google Gemini API kaliti (AI bot javoblari uchun) — maxfiy
# Olish: https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# AI modeli (ixtiyoriy) — default: gemini-flash-latest
# GEMINI_MODEL=gemini-flash-latest
